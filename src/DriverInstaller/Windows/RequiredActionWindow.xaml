<Window x:Class="IPhoneMirror.DriverInstaller.Windows.RequiredActionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="需要你的操作" Width="520" Height="320" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        Foreground="{StaticResource TextBrush}" ShowInTaskbar="False">
    <Border Background="{StaticResource AppBackground}" BorderBrush="#454545"
            BorderThickness="1" CornerRadius="8">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid MouseLeftButtonDown="OnHeaderMouseLeftButtonDown">
            <TextBlock Text="{Binding ActionTitle}" FontSize="20" FontWeight="SemiBold"/>
            <Button Content="×" HorizontalAlignment="Right" Width="32" Height="32"
                    MinHeight="32" Padding="0" FontSize="18" FontWeight="Normal"
                    Click="OnCancelClick"/>
        </Grid>
        <Border Grid.Row="2" Style="{StaticResource Section}">
            <TextBlock Text="{Binding ActionBody}" TextWrapping="Wrap" FontSize="13"
                       LineHeight="21" VerticalAlignment="Center"/>
        </Border>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Click="OnCancelClick" MinWidth="88" Margin="0,0,8,0"/>
            <Button Content="{Binding ConfirmText}" Style="{StaticResource PrimaryButton}"
                    Click="OnConfirmClick" MinWidth="132"/>
        </StackPanel>
    </Grid>
    </Border>
</Window>
