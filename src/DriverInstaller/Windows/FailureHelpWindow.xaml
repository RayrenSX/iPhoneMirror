<Window x:Class="IPhoneMirror.DriverInstaller.Windows.FailureHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="驱动处理失败" Width="620" Height="450" MinHeight="420"
        WindowStartupLocation="CenterOwner" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        Foreground="{StaticResource TextBrush}" ShowInTaskbar="False">
    <Border Background="{StaticResource AppBackground}" BorderBrush="#454545"
            BorderThickness="1" CornerRadius="8">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid MouseLeftButtonDown="OnHeaderMouseLeftButtonDown">
            <TextBlock Text="未能完成驱动操作" FontSize="21" FontWeight="SemiBold"/>
            <Button Content="×" HorizontalAlignment="Right" Width="32" Height="32"
                    MinHeight="32" Padding="0" FontSize="18" FontWeight="Normal"
                    Click="OnCloseClick"/>
        </Grid>
        <Border Grid.Row="2" Background="#2B1719" BorderBrush="#6A3035"
                BorderThickness="1" CornerRadius="7" Padding="13">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FFD9DC"
                       TextWrapping="Wrap" MaxHeight="90"/>
        </Border>
        <StackPanel Grid.Row="4">
            <TextBlock Text="可以选择以下一种处理方式" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <Border Style="{StaticResource Section}" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="获取人工帮助" FontWeight="SemiBold"/>
                        <TextBlock Text="加入 QQ 群 1050045279，并提供操作日志。"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="复制群号" Click="OnCopyGroupClick"
                            MinWidth="104" Margin="12,0,0,0"/>
                </Grid>
            </Border>
            <Border Style="{StaticResource Section}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="使用爱思投屏完成驱动准备" FontWeight="SemiBold"/>
                        <TextBlock Text="从爱思官网下载并完成一次正常有线投屏，然后返回重新检测。"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="打开官网" Click="OnOpenAisiClick"
                            MinWidth="104" Margin="12,0,0,0"/>
                </Grid>
            </Border>
        </StackPanel>
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="关闭" Click="OnCloseClick" MinWidth="88" Margin="0,0,8,0"/>
            <Button Content="重新检测" Style="{StaticResource PrimaryButton}"
                    Click="OnRetryClick" MinWidth="112"/>
        </StackPanel>
    </Grid>
    </Border>
</Window>
