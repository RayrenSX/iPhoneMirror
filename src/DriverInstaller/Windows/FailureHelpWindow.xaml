<Window x:Class="IPhoneMirror.DriverInstaller.Windows.FailureHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource FailureTitle}" Width="620" Height="450" MinHeight="420"
        WindowStartupLocation="CenterOwner" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        Foreground="{StaticResource TextBrush}" ShowInTaskbar="False">
    <Border Background="{StaticResource AppBackground}" BorderBrush="#454545"
            BorderThickness="1" CornerRadius="8">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid MouseLeftButtonDown="OnHeaderMouseLeftButtonDown">
            <TextBlock Text="{DynamicResource FailureHeading}" FontSize="21" FontWeight="SemiBold"/>
            <Button Content="×" HorizontalAlignment="Right" Width="32" Height="32"
                    MinHeight="32" Padding="0" FontSize="18" FontWeight="Normal"
                    Click="OnCloseClick"/>
        </Grid>
        <Border Grid.Row="2" Background="#2B1719" BorderBrush="#6A3035"
                BorderThickness="1" CornerRadius="7" Padding="13">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FFD9DC"
                       TextWrapping="Wrap" MaxHeight="90"/>
        </Border>
        <StackPanel Grid.Row="4">
            <TextBlock Text="{DynamicResource FailureMethods}" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <Border Style="{StaticResource Section}" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource HelpTitle}" FontWeight="SemiBold"/>
                        <TextBlock Text="{DynamicResource HelpBody}"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="{DynamicResource CopyGroup}" Click="OnCopyGroupClick"
                            MinWidth="104" Margin="12,0,0,0"/>
                </Grid>
            </Border>
            <Border Style="{StaticResource Section}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource AisiTitle}" FontWeight="SemiBold"/>
                        <TextBlock Text="{DynamicResource AisiBody}"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="{DynamicResource OpenWebsite}" Click="OnOpenAisiClick"
                            MinWidth="104" Margin="12,0,0,0"/>
                </Grid>
            </Border>
        </StackPanel>
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Close}" Click="OnCloseClick" MinWidth="88" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource Retry}" Style="{StaticResource PrimaryButton}"
                    Click="OnRetryClick" MinWidth="112"/>
        </StackPanel>
    </Grid>
    </Border>
</Window>
