<Window x:Class="IPhoneMirror.DriverInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iPhoneMirror 驱动管理器"
        Icon="pack://application:,,,/Assets/iPhoneMirror.ico"
        Width="1120" Height="720" MinWidth="960" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackground}"
        Foreground="{StaticResource TextBrush}"
        Loaded="OnLoaded">
    <Window.Resources>
        <Style x:Key="DeviceItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="#303030" BorderThickness="1"
                                CornerRadius="7" Padding="13,11">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#202020"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#292929"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#E6E6E6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="iPhoneMirror 驱动管理器" FontSize="24" FontWeight="SemiBold"/>
                <TextBlock Text="Apple USB 环境与按设备采集过滤驱动"
                           Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                        Visibility="{Binding AdvancedVisibility}">
                <Button Content="打开日志" Click="OnOpenLogsClick"
                        IsEnabled="{Binding CanInteract}" MinWidth="96" Margin="0,0,8,0"/>
                <Button Content="刷新" Click="OnRefreshClick"
                        IsEnabled="{Binding CanInteract}" MinWidth="84"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource Section}" Padding="14">
            <Border.Visibility>
                <Binding Path="AdvancedVisibility"/>
            </Border.Visibility>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Margin="2,0,18,0">
                    <TextBlock Text="Apple USB 环境" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                    <TextBlock Text="{Binding AppleStatusText}" Margin="0,5,0,0"
                               FontWeight="SemiBold" TextWrapping="Wrap"/>
                </StackPanel>
                <Border Grid.Column="1" Background="{StaticResource BorderBrush}"/>
                <StackPanel Grid.Column="2" Margin="18,0">
                    <TextBlock Text="采集过滤驱动" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                    <TextBlock Text="{Binding LibUsbStatusText}" Margin="0,5,0,0"
                               FontWeight="SemiBold" TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="3" Content="安装 Apple Devices"
                        Click="OnInstallAppleSupportClick"
                        IsEnabled="{Binding CanInstallAppleSupport}"
                        MinWidth="150" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.RowSpan="3" Style="{StaticResource Section}"
                Visibility="{Binding SimpleVisibility}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        MaxWidth="620">
                <TextBlock Text="一键准备投屏环境" FontSize="22" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="自动检测并安装 Apple USB 支持、共享采集驱动，以及当前已连接 iPhone 的采集过滤器。"
                           Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"
                           TextAlignment="Center" Margin="0,10,0,18"/>
                <ComboBox ItemsSource="{Binding ConnectedDevices}"
                          SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                          DisplayMemberPath="SelectionText"
                          MinWidth="320" Height="38" Margin="0,0,0,12"
                          IsEnabled="{Binding CanInteract}"/>
                <Button Content="一键安装全部驱动" Style="{StaticResource PrimaryButton}"
                        Click="OnQuickInstallClick" IsEnabled="{Binding CanQuickInstall}"
                        Height="54" MinWidth="250" FontSize="16" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding SelectedDevice.DetailText, TargetNullValue=请先连接 iPhone}"
                           Foreground="#777777" FontSize="10"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock Text="{Binding OperationStatus}" Foreground="{StaticResource MutedBrush}"
                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,18,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="4">
            <Grid.Visibility>
                <Binding Path="AdvancedVisibility"/>
            </Grid.Visibility>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Section}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Apple 设备" FontSize="15" FontWeight="SemiBold"/>
                    <ListBox Grid.Row="2" ItemsSource="{Binding Devices}"
                             SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource DeviceItem}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <TextBlock Text="{Binding SelectionText}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding ConnectionText}" HorizontalAlignment="Right"
                                                   Foreground="{StaticResource MutedBrush}" FontSize="10"/>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Text="{Binding DriverText}" Margin="0,5,0,0"
                                               Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                                    <TextBlock Grid.Row="2" Text="{Binding DetailText}" Margin="0,5,0,0"
                                               Foreground="#777777" FontFamily="Consolas" FontSize="9"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Section}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="当前设备" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Text="{Binding SelectedDevice.DisplayName, TargetNullValue=未选择设备}"
                                   FontSize="20" FontWeight="SemiBold" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="112"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="设备实例" Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding SelectedDevice.InstanceId, TargetNullValue=—}"
                                   FontFamily="Consolas" TextWrapping="Wrap"/>
                        <TextBlock Grid.Row="1" Text="连接状态" Foreground="{StaticResource MutedBrush}"
                                   Margin="0,11,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding SelectedDevice.ConnectionText, TargetNullValue=—}"
                                   Margin="0,11,0,0"/>
                        <TextBlock Grid.Row="2" Text="驱动状态" Foreground="{StaticResource MutedBrush}"
                                   Margin="0,11,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding SelectedDevice.DriverText, TargetNullValue=—}"
                                   Margin="0,11,0,0"/>
                    </Grid>

                    <StackPanel Grid.Row="3" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding OperationStatus}" TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,0,0,14"/>
                        <ProgressBar Height="3" IsIndeterminate="True"
                                     Visibility="{Binding BusyVisibility}"
                                     Foreground="#F2F2F2" Background="#303030"/>
                    </StackPanel>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="{Binding InstallButtonText}" Style="{StaticResource PrimaryButton}"
                                Click="OnInstallClick" IsEnabled="{Binding CanInstallDriver}"/>
                        <Button Grid.Column="2" Content="修复" Click="OnRepairClick"
                                IsEnabled="{Binding CanRepairDriver}"/>
                        <Button Grid.Column="4" Content="卸载" Style="{StaticResource DangerButton}"
                                Click="OnUninstallClick" IsEnabled="{Binding CanUninstallDriver}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="6">
            <TextBlock Text="驱动更改仅作用于选中的 Apple USB 父设备；不会替换 Apple 官方驱动。"
                       Foreground="{StaticResource MutedBrush}" FontSize="10"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{Binding AdvancedButtonText}" Click="OnAdvancedClick"
                        MinHeight="28" Padding="12,4" FontSize="11"/>
                <TextBlock Text="libusb-win32 1.2.6.0" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="12,0,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
