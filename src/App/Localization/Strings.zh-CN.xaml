    <system:String x:Key="DriverHelpTitle">iPhoneMirror 驱动与信任帮助</system:String>
    <system:String x:Key="DriverHelpBody">1. 安装 Apple Devices（Microsoft Store）或 iTunes 桌面版以获得 Apple Mobile Device Support。&#10;&#10;2. 解锁 iPhone 或 iPad，并点击“信任此电脑”。&#10;&#10;3. QuickTime 隐藏 USB 配置需要兼容过滤驱动。本程序不会替换 Apple 官方驱动。</system:String>
    <system:String x:Key="DriverHelpIntro">完成以下三项后即可稳定使用 USB 投屏。</system:String>
