<Window x:Class="IPhoneMirror.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:IPhoneMirror.App.Controls"
        mc:Ignorable="d"
        Title="{DynamicResource WindowTitleConnectivity}"
        Icon="pack://application:,,,/Assets/iPhoneMirror.ico"
        Width="1420" Height="860" MinWidth="1240" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        PreviewKeyDown="OnPreviewKeyDown">
    <Window.Resources>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="AutomationProperties.AutomationId" Value="{Binding Udid}"/>
            <Setter Property="AutomationProperties.Name" Value="{Binding DisplayName}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Card" Background="{StaticResource PanelAltBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="5" Padding="14">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#202020"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="#5A5A5A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Card" Property="Background" Value="#242424"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,13,0,3"/>
        </Style>
        <Style x:Key="ControlSectionCard" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="0,14,0,0"/>
            <Setter Property="Margin" Value="0,14,0,0"/>
        </Style>
        <Style x:Key="ControlSectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="ToolButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="8,7"/>
        </Style>
        <Style x:Key="UsbModeTabItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="7,6"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="TabRoot" Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="1"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabRoot" Property="Background" Value="#252525"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabRoot" Property="Background" Value="#F2F2F2"/>
                                <Setter TargetName="TabRoot" Property="BorderBrush" Value="#F2F2F2"/>
                                <Setter Property="Foreground" Value="#0D0D0D"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="UsbModeInfoButton" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="MinHeight" Value="18"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#343434"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="InfoRoot" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <TextBlock Text="!" Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="InfoRoot" Property="Background" Value="#5A5A5A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="InfoRoot" Property="Background" Value="#202020"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CaptureActionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="132"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Background" Value="#F2F2F2"/>
            <Setter Property="BorderBrush" Value="#F2F2F2"/>
            <Setter Property="Foreground" Value="#0D0D0D"/>
            <Setter Property="Content" Value="{DynamicResource StartMirroring}"/>
            <Setter Property="Command" Value="{Binding StartCommand}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionRoot" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionRoot" Property="Opacity" Value="0.72"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ActionRoot" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="ActionRoot" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ActionRoot" Property="Opacity" Value="0.34"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasCaptureSession}" Value="True">
                    <Setter Property="Background" Value="#C93645"/>
                    <Setter Property="BorderBrush" Value="#C93645"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Content" Value="{DynamicResource StopMirroring}"/>
                    <Setter Property="Command" Value="{Binding StopCommand}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootLayout" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition x:Name="HeaderGapRow" Height="18"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="HeaderPanel" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="iPhoneMirror" FontSize="24" FontWeight="SemiBold"/>
                <TextBlock Text="{DynamicResource AppSubtitleConnectivity}" Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>
            <Border Grid.Column="1" Padding="0" VerticalAlignment="Center"
                    Background="Transparent" BorderThickness="0" MaxWidth="360">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="6" Height="6" Fill="{StaticResource WarningBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding DriverState}" FontSize="12" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>
            <ComboBox x:Name="LanguageComboBox" Grid.Column="3" Width="142" Height="40"
                      VerticalAlignment="Center"
                      SelectedValue="{Binding SelectedLanguage, Mode=TwoWay}"
                      SelectedValuePath="Tag"
                      ToolTip="{DynamicResource LanguageToolTip}">
                <ComboBoxItem Tag="system" Content="{DynamicResource LanguageSystem}"/>
                <ComboBoxItem Tag="zh-CN" Content="{DynamicResource LanguageChinese}"/>
                <ComboBoxItem Tag="en-US" Content="{DynamicResource LanguageEnglish}"/>
            </ComboBox>
            <Button Grid.Column="5" Width="116" Height="40" Padding="12,8"
                    Content="{DynamicResource DriverManagerButton}"
                    Command="{Binding OpenDriverManagerCommand}"
                    ToolTip="{DynamicResource DriverManagerToolTip}"
                    AutomationProperties.AutomationId="DriverManagerButton"
                    VerticalAlignment="Center" FontSize="13"/>
            <Button x:Name="CaptureActionButton" Grid.Column="7"
                    AutomationProperties.AutomationId="CaptureActionButton"
                    Style="{StaticResource CaptureActionButton}"
                    VerticalAlignment="Center"/>
        </Grid>

        <Grid x:Name="MainContentGrid" Grid.Row="2" UseLayoutRounding="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="DeviceColumn" Width="300"/>
                <ColumnDefinition x:Name="LeftGapColumn" Width="18"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="RightGapColumn" Width="18"/>
                <ColumnDefinition x:Name="ControlColumn" Width="336"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="DevicePanel" Grid.Column="0" Style="{StaticResource CardBorder}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <TextBlock Text="{DynamicResource DevicesTitle}" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding DeviceCount}" Foreground="{StaticResource MutedTextBrush}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                    </Grid>
                    <Border Grid.Row="2" Style="{StaticResource ControlSectionCard}" Margin="0" Padding="12">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="{DynamicResource CurrentDevice}" Style="{StaticResource ControlSectionTitle}"/>
                                <TextBlock Text="{Binding SelectedConnection}" HorizontalAlignment="Right"
                                           Foreground="{StaticResource MutedTextBrush}" FontSize="10"/>
                            </Grid>
                            <TextBlock Text="{Binding SelectedName}" FontSize="15" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" Margin="0,9,0,0"/>
                            <TextBlock Text="{Binding SelectedModel}" Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="11" Margin="0,3,0,0"/>
                            <TextBlock Text="{Binding SelectedOs}" Foreground="{StaticResource MutedTextBrush}" FontSize="11"/>
                            <TextBlock Text="{Binding SelectedUdid}" FontFamily="Consolas" FontSize="9"
                                       AutomationProperties.AutomationId="SelectedDeviceUdidText"
                                       Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis"
                                       Margin="0,7,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="3" Height="1" Background="{StaticResource BorderSoftBrush}"
                            VerticalAlignment="Center" Margin="2,0"/>
                    <ListBox x:Name="DeviceListBox" Grid.Row="4" ItemsSource="{Binding Devices}"
                             SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                             AllowDrop="True"
                             PreviewMouseLeftButtonDown="OnDeviceListLeftButtonDown"
                             PreviewMouseMove="OnDeviceListMouseMove"
                             PreviewMouseLeftButtonUp="OnDeviceListLeftButtonUp"
                             PreviewMouseRightButtonDown="OnDeviceListRightButtonDown"
                             DragOver="OnDeviceListDragOver"
                             Drop="OnDeviceListDrop">
                        <ListBox.Resources>
                            <Style TargetType="ContextMenu">
                                <Setter Property="Background" Value="#151515"/>
                                <Setter Property="Foreground" Value="#F2F2F2"/>
                                <Setter Property="BorderBrush" Value="#3A3A3A"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Padding" Value="5"/>
                                <Setter Property="HasDropShadow" Value="True"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ContextMenu">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="7" Padding="{TemplateBinding Padding}">
                                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                            <Style TargetType="MenuItem">
                                <Setter Property="Foreground" Value="#F2F2F2"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Padding" Value="14,9"/>
                                <Setter Property="MinWidth" Value="150"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="MenuItem">
                                            <Border x:Name="MenuRoot" Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter ContentSource="Header"
                                                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsHighlighted" Value="True">
                                                    <Setter TargetName="MenuRoot" Property="Background" Value="#292929"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                            <ContextMenu x:Key="DeviceContextMenu" Placement="MousePoint">
                                <MenuItem Header="{DynamicResource MirrorSimultaneously}"
                                          Click="OnMirrorSimultaneouslyClick"/>
                            </ContextMenu>
                        </ListBox.Resources>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem"
                                   BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="ContextMenu" Value="{StaticResource DeviceContextMenu}"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="32" Height="48" CornerRadius="6" BorderThickness="2"
                                            BorderBrush="{StaticResource MutedTextBrush}" VerticalAlignment="Top">
                                        <Ellipse Width="3" Height="3" Fill="{StaticResource MutedTextBrush}"
                                                 VerticalAlignment="Top" Margin="0,4,0,0"/>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding ModelDisplay}" Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="11" Margin="0,3,0,0"/>
                                        <TextBlock Text="{Binding OsDisplay}" Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="11"/>
                                        <TextBlock Text="{Binding StatusDisplay}" Foreground="{StaticResource SuccessBrush}"
                                                   FontSize="10" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="5">
                        <Button x:Name="RefreshDevicesButton"
                                Content="{DynamicResource RefreshDevices}" Command="{Binding RefreshCommand}"
                                Background="{StaticResource PanelAltBrush}"/>
                        <TextBlock Text="{DynamicResource KeepUnlocked}" Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="11" TextAlignment="Center" Margin="0,9,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="CenterPanel" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition x:Name="EnvironmentGapRow" Height="14"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition x:Name="StatsGapRow" Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition x:Name="LogGapRow" Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border x:Name="EnvironmentPanel" Grid.Row="0" Style="{StaticResource CardBorder}" Padding="14">
                    <TextBlock Text="{Binding EnvironmentStatus}" Foreground="{StaticResource WarningBrush}"
                               FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <Border x:Name="PreviewPanel" Grid.Row="2" Background="#050505" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" ClipToBounds="True"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        MinWidth="0" MinHeight="0" SnapsToDevicePixels="True">
                    <Grid>
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <StackPanel x:Name="WaitingForDeviceState"
                                        AutomationProperties.AutomationId="WaitingForDeviceState"
                                        HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="440">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedDevice}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <Border Width="92" Height="92" CornerRadius="46"
                                        Background="#111111" BorderBrush="#3C3C3C" BorderThickness="1"
                                        HorizontalAlignment="Center">
                                    <Grid>
                                        <Path Width="38" Height="48"
                                              Data="M13,2 L25,2 C31,2 35,6 35,12 L35,36 C35,42 31,46 25,46 L13,46 C7,46 3,42 3,36 L3,12 C3,6 7,2 13,2 Z M15,7 L23,7"
                                              Stroke="#A3A3A3" StrokeThickness="2"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Stretch="Uniform"/>
                                    </Grid>
                                </Border>
                                <TextBlock Text="{DynamicResource StatusWaitingDevice}"
                                           FontSize="21" FontWeight="SemiBold" TextAlignment="Center"
                                           Margin="0,20,0,0"/>
                                <TextBlock Text="{DynamicResource KeepUnlocked}"
                                           Foreground="{StaticResource MutedTextBrush}" FontSize="12"
                                           TextAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,0"/>
                            </StackPanel>

                            <StackPanel x:Name="ReadyToMirrorState"
                                        AutomationProperties.AutomationId="ReadyToMirrorState"
                                        HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="440">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedDevice}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <Border Width="84" Height="126" CornerRadius="12" BorderThickness="2"
                                        BorderBrush="#666666" HorizontalAlignment="Center">
                                    <Grid>
                                        <Border Width="30" Height="4" CornerRadius="2" Background="#666666"
                                                VerticalAlignment="Top" Margin="0,8,0,0"/>
                                        <TextBlock Text="{Binding SelectedConnection}" Foreground="{StaticResource MutedTextBrush}"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding SelectedName}" FontSize="20" FontWeight="SemiBold"
                                           TextAlignment="Center" Margin="0,20,0,0"/>
                                <TextBlock Text="{Binding CaptureStatus}" Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12" TextAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                        <controls:NativePreviewHost x:Name="MainPreviewHost">
                            <controls:NativePreviewHost.Style>
                                <Style TargetType="{x:Type controls:NativePreviewHost}">
                                    <!-- HwndHost airspace cannot be painted over by WPF. Remove it
                                         from idle layout entirely instead of shrinking it through an
                                         intermediate native surface that DWM can expose for a frame. -->
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="IsHitTestVisible" Value="False"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </controls:NativePreviewHost.Style>
                        </controls:NativePreviewHost>
                    </Grid>
                </Border>

                <Border x:Name="StatsPanel" Grid.Row="4" Style="{StaticResource CardBorder}" Padding="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="13">
                            <TextBlock Text="{DynamicResource ResolutionLabel}" Style="{StaticResource StatLabel}"/>
                            <TextBlock Text="{Binding Resolution}" Style="{StaticResource StatValue}"/>
                            <TextBlock Text="{Binding TargetResolutionDisplay}" Foreground="{StaticResource MutedTextBrush}" FontSize="10" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="{StaticResource BorderSoftBrush}" Margin="0,10"/>
                        <StackPanel Grid.Column="2" Margin="13">
                            <TextBlock Text="{DynamicResource FrameRateLabel}" Style="{StaticResource StatLabel}"/>
                            <TextBlock Text="{Binding FpsDisplay}" Style="{StaticResource StatValue}"/>
                            <TextBlock Text="{Binding TargetFpsDisplay}" Foreground="{StaticResource MutedTextBrush}" FontSize="10"/>
                        </StackPanel>
                        <Border Grid.Column="3" Background="{StaticResource BorderSoftBrush}" Margin="0,10"/>
                        <StackPanel Grid.Column="4" Margin="13">
                            <TextBlock Text="{DynamicResource LatencyLabel}" Style="{StaticResource StatLabel}"/>
                            <TextBlock Text="{Binding LatencyDisplay}" Style="{StaticResource StatValue}"/>
                            <TextBlock Text="{DynamicResource EndToEndLabel}" Foreground="{StaticResource MutedTextBrush}" FontSize="10"/>
                        </StackPanel>
                        <Border Grid.Column="5" Background="{StaticResource BorderSoftBrush}" Margin="0,10"/>
                        <StackPanel Grid.Column="6" Margin="13">
                            <TextBlock Text="{DynamicResource AudioLabel}" Style="{StaticResource StatLabel}"/>
                            <TextBlock Text="{Binding AudioDisplay}" Style="{StaticResource StatValue}"/>
                            <TextBlock Text="48 kHz PCM" Foreground="{StaticResource MutedTextBrush}" FontSize="10"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Expander x:Name="LogExpander" Grid.Row="6" Header="{DynamicResource LiveLogHeader}"
                          Foreground="{StaticResource TextBrush}" IsExpanded="False"
                          Expanded="OnLogExpanded" Collapsed="OnLogCollapsed">
                    <Border Style="{StaticResource CardBorder}" Padding="10" Margin="0,6,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="150"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <TextBlock Text="{Binding LogPathDisplay}" FontFamily="Consolas" FontSize="10"
                                           Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis"/>
                                <Button Content="{DynamicResource ClearView}" Command="{Binding ClearLogCommand}"
                                        HorizontalAlignment="Right" Padding="10,4" FontSize="11"
                                        Background="{StaticResource PanelAltBrush}"/>
                            </Grid>
                            <Border Grid.Row="2"
                                    Background="#0B0B0B"
                                    BorderBrush="#292929"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    ClipToBounds="True">
                                <TextBox x:Name="LogTextBox" Text="{Binding LogText, Mode=OneWay}"
                                         IsReadOnly="True" FontFamily="Consolas" FontSize="10"
                                         Foreground="#D7D7D7" Background="Transparent" BorderThickness="0"
                                         Padding="10" TextWrapping="NoWrap"
                                         SelectionBrush="{StaticResource AccentBrush}" SelectionOpacity="0.35"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                         TextChanged="OnLogTextChanged"/>
                            </Border>
                        </Grid>
                    </Border>
                </Expander>
            </Grid>

            <Border x:Name="ControlPanel" Grid.Column="4" Style="{StaticResource CardBorder}" Padding="16,16,7,16">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              PanningMode="VerticalOnly">
                    <StackPanel Margin="0,0,7,0">
                        <TextBlock Text="{DynamicResource ControlTitle}" FontSize="16" FontWeight="SemiBold"/>

                        <Border Style="{StaticResource ControlSectionCard}"
                                Visibility="{Binding WirelessTopSettingsVisibility}">
                            <StackPanel>
                                <Grid><TextBlock Text="{DynamicResource WirelessReceiverTitle}" Style="{StaticResource ControlSectionTitle}"/><TextBlock Text="{DynamicResource WirelessServiceAlwaysOn}" HorizontalAlignment="Right" Foreground="{StaticResource SuccessBrush}" FontSize="10"/></Grid>
                                <TextBlock Text="{DynamicResource WirelessResolutionLabel}" Style="{StaticResource DetailLabel}" Margin="0,10,0,5"/>
                                <ComboBox ItemsSource="{Binding WirelessDisplayProfiles}" DisplayMemberPath="Label" SelectedItem="{Binding SelectedWirelessDisplayProfile, Mode=TwoWay}"/>
                                <TextBlock Text="{DynamicResource WirelessResolutionHelp}" Foreground="{StaticResource MutedTextBrush}" FontSize="9" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                <Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox Text="{Binding WirelessReceiverName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource RoundedTextBox}" MaxLength="63" Height="36" ToolTip="{DynamicResource WirelessReceiverNameLabel}"/><Button Grid.Column="2" Content="{DynamicResource ApplyWirelessSettings}" Command="{Binding ApplyWirelessSettingsCommand}" Style="{StaticResource ToolButton}" MinWidth="64"/></Grid>
                                <TextBlock Text="{Binding WirelessStatus}" Foreground="{StaticResource MutedTextBrush}" FontSize="10" TextWrapping="Wrap" Margin="1,8,0,0"/>
                                <TextBlock Text="{Binding AppliedWirelessProfileDisplay}" Foreground="{StaticResource MutedTextBrush}" FontSize="9" TextWrapping="Wrap" Margin="1,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ControlSectionCard}"
                                Visibility="{Binding UsbProjectionSettingsVisibility}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource UsbProjectionModeTitle}"
                                           Style="{StaticResource ControlSectionTitle}"/>
                                <Border Background="#151515" BorderBrush="#343434"
                                        BorderThickness="1" CornerRadius="7"
                                        Padding="2" Margin="0,9,0,0">
                                    <ListBox ItemsSource="{Binding UsbProjectionModes}"
                                             SelectedItem="{Binding SelectedUsbProjectionMode, Mode=TwoWay}"
                                             IsEnabled="{Binding CanChangeUsbProjectionMode}"
                                             ItemContainerStyle="{StaticResource UsbModeTabItem}"
                                             Background="Transparent" BorderThickness="0" Padding="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Rows="1" Columns="3"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <TextBlock Text="{Binding Label}" FontSize="9"
                                                               FontWeight="SemiBold" TextWrapping="Wrap"
                                                               TextAlignment="Center" VerticalAlignment="Center"
                                                               Margin="0,0,20,0"
                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"/>
                                                    <Button Style="{StaticResource UsbModeInfoButton}"
                                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                                            Click="OnUsbProjectionModeInfoClick"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                                <TextBlock Text="{DynamicResource UsbProjectionPerDeviceHint}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="9" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ControlSectionCard}" Visibility="Collapsed">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="{DynamicResource CurrentDevice}" Style="{StaticResource ControlSectionTitle}"/>
                                    <TextBlock Text="{Binding SelectedConnection}"
                                               HorizontalAlignment="Right"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="10"/>
                                </Grid>
                                <TextBlock Text="{Binding SelectedName}" FontSize="15" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" Margin="0,11,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding SelectedModel}" FontSize="11"/>
                                    <TextBlock Text="  ·  " Foreground="{StaticResource MutedTextBrush}" FontSize="11"/>
                                    <TextBlock Text="{Binding SelectedOs}" Foreground="{StaticResource MutedTextBrush}" FontSize="11"/>
                                </StackPanel>
                                <TextBlock Text="UDID" Style="{StaticResource DetailLabel}" Margin="0,9,0,3"/>
                                <TextBlock Text="{Binding SelectedUdid}" FontFamily="Consolas" FontSize="9"
                                           AutomationProperties.AutomationId="SelectedDeviceUdidText"
                                           Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ControlSectionCard}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource ImageAndSound}" Style="{StaticResource ControlSectionTitle}"/>
                                <StackPanel Visibility="{Binding WiredVideoLimitSettingsVisibility}">
                                    <TextBlock Text="{DynamicResource RenderLimitHelp}"
                                               Foreground="{StaticResource MutedTextBrush}" FontSize="9"
                                               TextWrapping="Wrap" Margin="0,4,0,1"/>

                                    <TextBlock Text="{DynamicResource RenderResolutionLimit}" Style="{StaticResource DetailLabel}" Margin="0,10,0,5"/>
                                    <ComboBox x:Name="ResolutionComboBox"
                                              ItemsSource="{Binding ResolutionPresets}"
                                              DisplayMemberPath="Label"
                                              SelectedItem="{Binding SelectedResolutionPreset, Mode=TwoWay}"/>

                                    <TextBlock Text="{DynamicResource TargetFrameRate}" Style="{StaticResource DetailLabel}" Margin="0,10,0,5"/>
                                    <ComboBox x:Name="FrameRateComboBox"
                                              ItemsSource="{Binding FrameRates}"
                                              SelectedItem="{Binding SelectedFrameRate, Mode=TwoWay}"/>

                                    <Button x:Name="ApplyVideoSettingsButton"
                                            Content="{DynamicResource ApplyVideoSettings}"
                                            Command="{Binding ApplyVideoSettingsCommand}"
                                            Style="{StaticResource ToolButton}"
                                            Margin="0,10,0,0"/>
                                    <TextBlock Text="{Binding SettingsStatus}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="9" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                </StackPanel>

                                <Border Height="1" Background="{StaticResource BorderSoftBrush}" Margin="0,12,0,11"/>
                                <CheckBox x:Name="AudioPlaybackCheckBox"
                                          Content="{DynamicResource PlayAudioWindows}"
                                          IsChecked="{Binding PlayAudio, Mode=TwoWay}"/>
                                <Grid Margin="0,9,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource PlaybackVolume}" Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="10" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding PlaybackVolume, StringFormat={}{0:F0}%}"
                                               Width="42" TextAlignment="Right"
                                               Foreground="{StaticResource AccentHoverBrush}"
                                               FontSize="10" FontWeight="SemiBold"/>
                                </Grid>
                                <Slider x:Name="VolumeSlider"
                                        Minimum="0" Maximum="100"
                                        Value="{Binding PlaybackVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Margin="0,4,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ControlSectionCard}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource PreviewAndObs}" Style="{StaticResource ControlSectionTitle}"/>
                                <UniformGrid Columns="2" Margin="0,10,0,0">
                                    <Button x:Name="RefreshPreviewButton" Content="{DynamicResource RefreshFrame}"
                                            Click="OnRefreshPreviewClick" Style="{StaticResource ToolButton}" Margin="0,0,4,4"/>
                                    <Button x:Name="FullScreenButton" Content="{DynamicResource FullScreenPreview}"
                                            Click="OnFullScreenClick" Style="{StaticResource ToolButton}" Margin="4,0,0,4"/>
                                    <Button x:Name="PreviewWindowButton" Content="{DynamicResource SeparateWindow}"
                                            Click="OnPreviewWindowClick" Style="{StaticResource ToolButton}" Margin="0,4,4,0"/>
                                    <Button x:Name="ScreenshotButton" Content="{DynamicResource Screenshot}"
                                            Click="OnScreenshotClick" Style="{StaticResource ToolButton}" Margin="4,4,0,0"/>
                                </UniformGrid>
                                <TextBlock Text="{DynamicResource ObsWindowHelp}"
                                           Foreground="{StaticResource MutedTextBrush}" FontSize="9"
                                           TextWrapping="Wrap" Margin="0,9,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="AdvancedSettingsCard"
                                Style="{StaticResource ControlSectionCard}"
                                Visibility="{Binding AdvancedSettingsVisibility}">
                            <StackPanel>
                                <Button Content="{DynamicResource AdvancedSettings}" Command="{Binding AdvancedSettingsCommand}"
                                        Style="{StaticResource ToolButton}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ControlSectionCard}"
                                Visibility="{Binding WirelessBottomSettingsVisibility}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="{DynamicResource WirelessReceiverTitle}"
                                               Style="{StaticResource ControlSectionTitle}"/>
                                    <TextBlock Text="{DynamicResource WirelessServiceAlwaysOn}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Foreground="{StaticResource SuccessBrush}" FontSize="10"/>
                                </Grid>
                                <TextBlock Text="{DynamicResource WirelessResolutionLabel}"
                                           Style="{StaticResource DetailLabel}" Margin="0,10,0,5"/>
                                <ComboBox ItemsSource="{Binding WirelessDisplayProfiles}"
                                          DisplayMemberPath="Label"
                                          SelectedItem="{Binding SelectedWirelessDisplayProfile, Mode=TwoWay}"
                                          AutomationProperties.AutomationId="WirelessResolutionComboBox"/>
                                <TextBlock Text="{DynamicResource WirelessResolutionHelp}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="9" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding WirelessReceiverName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource RoundedTextBox}"
                                             MaxLength="63" Height="36"
                                             ToolTip="{DynamicResource WirelessReceiverNameLabel}"/>
                                    <Button Grid.Column="2" Content="{DynamicResource ApplyWirelessSettings}"
                                            Command="{Binding ApplyWirelessSettingsCommand}"
                                            Style="{StaticResource ToolButton}" MinWidth="64"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="1,8,0,0">
                                    <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}"
                                             VerticalAlignment="Center" Margin="0,0,7,0"/>
                                    <TextBlock Text="{Binding WirelessStatus}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="10" TextWrapping="Wrap"/>
                                </StackPanel>
                                <TextBlock Text="{Binding AppliedWirelessProfileDisplay}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="9" TextWrapping="Wrap" Margin="1,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid x:Name="FooterPanel" Grid.Row="3" Margin="0,16,0,0">
            <TextBlock Text="{DynamicResource FooterConnectivity}" Foreground="{StaticResource MutedTextBrush}" FontSize="10"/>
            <TextBlock Text="{DynamicResource FooterVersionCurrent}" Foreground="{StaticResource MutedTextBrush}"
                       FontSize="10" HorizontalAlignment="Right" Cursor="Hand"
                       MouseLeftButtonDown="OnVersionClick"/>
        </Grid>

        <Popup x:Name="PreviewTransitionMask"
               PlacementTarget="{Binding ElementName=PreviewPanel}"
               Placement="Center"
               AllowsTransparency="True"
               StaysOpen="True"
               Focusable="False"
               IsHitTestVisible="False">
            <Grid Width="{Binding ActualWidth, ElementName=PreviewPanel}"
                  Height="{Binding ActualHeight, ElementName=PreviewPanel}"
                  Background="Transparent"
                  SnapsToDevicePixels="True"
                  UseLayoutRounding="True">
                <Border Margin="1,0,1,2"
                        Background="#050505"
                        CornerRadius="7"
                        SnapsToDevicePixels="True"/>
            </Grid>
        </Popup>
    </Grid>
</Window>
