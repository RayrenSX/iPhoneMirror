<Window x:Class="IPhoneMirror.App.Windows.UsbProjectionModeInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource UsbModeDetailsTitle}"
        Width="520" Height="470" MinWidth="520" MinHeight="470"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#0C0C0C" Foreground="#F4F4F4">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="{DynamicResource UsbModeDetailsTitle}" FontSize="13"
                       Foreground="#A9A9A9"/>
            <TextBlock x:Name="ModeTitle" FontSize="22" FontWeight="SemiBold"
                       TextWrapping="Wrap" Margin="0,5,0,0"/>
        </StackPanel>
        <StackPanel Grid.Row="2">
            <TextBlock Text="{DynamicResource UsbModeAdvantageTitle}"
                       FontSize="12" FontWeight="SemiBold"/>
            <TextBlock x:Name="AdvantageText" Foreground="#CFCFCF" FontSize="12"
                       TextWrapping="Wrap" LineHeight="19" Margin="0,6,0,0"/>
            <Border Height="1" Background="#2B2B2B" Margin="0,16,0,15"/>
            <TextBlock Text="{DynamicResource UsbModeDisadvantageTitle}"
                       FontSize="12" FontWeight="SemiBold"/>
            <TextBlock x:Name="DisadvantageText" Foreground="#CFCFCF" FontSize="12"
                       TextWrapping="Wrap" LineHeight="19" Margin="0,6,0,0"/>
            <Border Background="#171717" BorderBrush="#4A4A4A" BorderThickness="1"
                    CornerRadius="6" Padding="13" Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="18" Height="18" BorderBrush="White" BorderThickness="1"
                            CornerRadius="9" VerticalAlignment="Top">
                        <TextBlock Text="!" Foreground="White" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="NoticeText" Grid.Column="1" Foreground="#BDBDBD"
                               FontSize="11" TextWrapping="Wrap" LineHeight="18"/>
                </Grid>
            </Border>
        </StackPanel>
        <Button Grid.Row="4" Content="{DynamicResource Close}" Width="112" Height="38"
                HorizontalAlignment="Right" IsDefault="True" IsCancel="True"/>
    </Grid>
</Window>
