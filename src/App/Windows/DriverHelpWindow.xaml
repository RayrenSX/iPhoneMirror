<Window x:Class="IPhoneMirror.App.Windows.DriverHelpWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="{DynamicResource DriverHelpTitle}" Width="560" Height="510" WindowStartupLocation="CenterOwner"
 ResizeMode="NoResize" Background="#0C0C0C" Foreground="#F4F4F4">
 <Grid Margin="28">
  <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="18"/><RowDefinition Height="*"/><RowDefinition Height="18"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
  <StackPanel><TextBlock Text="{DynamicResource DriverHelpTitle}" FontSize="22" FontWeight="SemiBold"/><TextBlock Text="{DynamicResource DriverHelpIntro}" Margin="0,7,0,0" Foreground="#A9A9A9" FontSize="12" TextWrapping="Wrap"/></StackPanel>
  <StackPanel Grid.Row="2">
   <Border Background="#151515" BorderBrush="#2B2B2B" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,0,0,10"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Width="27" Height="27" CornerRadius="14" Background="#F2F2F2"><TextBlock Text="1" Foreground="#111" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/></Border><StackPanel Grid.Column="1"><TextBlock Text="{DynamicResource DriverHelpAppleTitle}" FontWeight="SemiBold" FontSize="14"/><TextBlock Text="{DynamicResource DriverHelpAppleBody}" Foreground="#A9A9A9" FontSize="11" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel></Grid></Border>
   <Border Background="#151515" BorderBrush="#2B2B2B" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,0,0,10"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Width="27" Height="27" CornerRadius="14" Background="#F2F2F2"><TextBlock Text="2" Foreground="#111" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/></Border><StackPanel Grid.Column="1"><TextBlock Text="{DynamicResource DriverHelpTrustTitle}" FontWeight="SemiBold" FontSize="14"/><TextBlock Text="{DynamicResource DriverHelpTrustBody}" Foreground="#A9A9A9" FontSize="11" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel></Grid></Border>
   <Border Background="#151515" BorderBrush="#2B2B2B" BorderThickness="1" CornerRadius="10" Padding="16"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Width="27" Height="27" CornerRadius="14" Background="#F2F2F2"><TextBlock Text="3" Foreground="#111" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/></Border><StackPanel Grid.Column="1"><TextBlock Text="{DynamicResource DriverHelpFilterTitle}" FontWeight="SemiBold" FontSize="14"/><TextBlock Text="{DynamicResource DriverHelpFilterBody}" Foreground="#A9A9A9" FontSize="11" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel></Grid></Border>
  </StackPanel>
  <Button Grid.Row="4" Content="{DynamicResource Close}" Width="112" Height="38" HorizontalAlignment="Right" IsDefault="True" Click="OnCloseClick"/>
 </Grid>
</Window>
