<Window x:Class="IPhoneMirror.App.Windows.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:IPhoneMirror.App.Controls"
        Title="iPhoneMirror OBS Preview"
        Icon="pack://application:,,,/Assets/iPhoneMirror.ico"
        Width="720" Height="900" MinWidth="320" MinHeight="240"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#050505"
        ShowInTaskbar="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Background="#050505">
        <controls:NativePreviewHost x:Name="PreviewHost"/>
    </Grid>
</Window>
