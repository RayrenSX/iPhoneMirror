<Window x:Class="IPhoneMirror.App.Windows.AdvancedSettingsWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="{DynamicResource AdvancedSettingsTitle}" Width="520" Height="450" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="#0C0C0C" Foreground="#F4F4F4">
 <Window.Resources>
  <Style TargetType="TextBox">
   <Setter Property="Background" Value="#101010"/><Setter Property="Foreground" Value="#F4F4F4"/>
   <Setter Property="BorderBrush" Value="#3A3A3A"/><Setter Property="BorderThickness" Value="1"/>
   <Setter Property="CaretBrush" Value="#F4F4F4"/><Setter Property="SelectionBrush" Value="#555555"/>
   <Setter Property="Padding" Value="10,0"/><Setter Property="Height" Value="56"/>
   <Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="TextWrapping" Value="NoWrap"/>
   <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox">
    <Border x:Name="InputBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7">
     <ScrollViewer x:Name="PART_ContentHost" Margin="10,0" VerticalAlignment="Stretch"
                   HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
    </Border>
    <ControlTemplate.Triggers><Trigger Property="IsKeyboardFocusWithin" Value="True"><Setter TargetName="InputBorder" Property="BorderBrush" Value="#F4F4F4"/><Setter TargetName="InputBorder" Property="BorderThickness" Value="1.5"/></Trigger></ControlTemplate.Triggers>
   </ControlTemplate></Setter.Value></Setter>
  </Style>
 </Window.Resources>
 <Grid Margin="28">
  <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="18"/><RowDefinition Height="*"/><RowDefinition Height="18"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
  <StackPanel><TextBlock Text="{DynamicResource AdvancedSettingsTitle}" FontSize="22" FontWeight="SemiBold"/><TextBlock Text="{DynamicResource AdvancedSettingsIntro}" Foreground="#A9A9A9" FontSize="12" TextWrapping="Wrap" Margin="0,7,0,0"/></StackPanel>
  <Border Grid.Row="2" Background="#151515" BorderBrush="#2B2B2B" BorderThickness="1" CornerRadius="10" Padding="18">
   <StackPanel>
    <TextBlock Text="{DynamicResource AdvancedUsbResolution}" FontWeight="SemiBold"/>
    <TextBlock Text="{DynamicResource AdvancedUsbResolutionHelp}" Foreground="#A9A9A9" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,12"/>
    <Grid Margin="0,5,0,0">
     <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
     <StackPanel>
      <TextBlock Text="{DynamicResource HeightLabel}" Foreground="#A9A9A9" FontSize="11"/>
      <TextBox x:Name="HeightBox" Margin="0,5,0,0" FontSize="16"/>
     </StackPanel>
     <TextBlock Grid.Column="1" Text="×" Foreground="#A9A9A9" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10"/>
     <StackPanel Grid.Column="2">
      <TextBlock Text="{DynamicResource WidthLabel}" Foreground="#A9A9A9" FontSize="11"/>
      <TextBox x:Name="WidthBox" Margin="0,5,0,0" FontSize="16"/>
     </StackPanel>
    </Grid>
    <TextBlock x:Name="ErrorText" Foreground="#E56B75" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"/>
   </StackPanel>
  </Border>
  <Grid Grid.Row="4"><Button Content="{DynamicResource DisableAdvancedMode}" Width="150" Height="38" HorizontalAlignment="Left" Click="OnDisableClick"/><Button Content="{DynamicResource Apply}" Width="112" Height="38" HorizontalAlignment="Right" IsDefault="True" Click="OnApplyClick"/></Grid>
 </Grid>
</Window>
